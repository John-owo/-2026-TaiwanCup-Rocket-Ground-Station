{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rocket-monitoring-system",
  "version": "0.1.0",
  "identifier": "com.taiwancup.rocketground",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": { "script": "pnpm dev", "cwd": "../src-ui" },
    "beforeBuildCommand": { "script": "pnpm build", "cwd": "../src-ui" }
  },
  "app": {
    "windows": [
      {
        "title": "Rocket Monitoring System",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
